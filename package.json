{
  "name": "leafymap-backend",
  "version": "1.0.0",
  "description": "Backend for Leafy Map - local events discovery platform",
  "main": "dist/server.js",
  "scripts": {
    "start": "node -r tsconfig-paths/register dist/server.js",
    "dev": "nodemon",
    "dev:prod": "cross-env DOTENV_CONFIG_PATH=.env.prod nodemon",
    "build": "tsc && tsc-alias -p tsconfig.json",
    "render:build": "npm install --include=dev && npm run build",
    "watch": "tsc -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest __tests__/repositories __tests__/favorites/infrastructure --testPathIgnorePatterns=/node_modules/",
    "create:admin": "ts-node -r tsconfig-paths/register scripts/create-admin.ts",
    "seed:categories": "ts-node -r tsconfig-paths/register scripts/seed-categories.ts",
    "seed:users": "ts-node -r tsconfig-paths/register scripts/seed-paris.ts",
    "migrate:events-user": "ts-node -r tsconfig-paths/register scripts/migrate-events-user.ts",
    "knip": "knip",
    "lint": "eslint .",
    "lint:ci": "eslint . --max-warnings 79",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.817.0",
    "@aws-sdk/s3-request-presigner": "^3.817.0",
    "@types/node-cron": "^3.0.11",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.0.3",
    "multer": "^2.2.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.3",
    "sharp": "^0.34.3",
    "socket.io": "^4.8.3",
    "tsconfig-paths": "^4.2.0",
    "winston": "^3.17.0",
    "zod": "^3.25.73"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/mongoose": "^5.11.97",
    "@types/multer": "^1.4.12",
    "@types/multer-s3": "^3.0.3",
    "@types/node": "^22.15.29",
    "@types/nodemailer": "^7.0.9",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "jest": "^30.2.0",
    "knip": "^6.25.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.10",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.63.0"
  },
  "engines": {
    "node": ">=22.x"
  }
}
