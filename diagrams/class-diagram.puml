@startuml
title LeafyMap backend - services et entites BDD

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam packageStyle rectangle
skinparam linetype ortho
hide empty methods

package "Services" {
  class AwsService
  class EmailService
  class ImageProcessingService
  class SocketService
  class EventsCronService
  class EventStatusService
  class ScheduleService
  class ReviewService
  class FollowService
  class NotificationService
  class EventInvitationService
}

package "Entites principales" {
  class User {
    userType: creator|guest
    email
    place
  }

  class Place {
    location
    placeType: food|art|craft[]
    rating
  }

  class Event {
    name
    schedule
    status
    lifecycleStatus
  }

  class Product
}

package "Interactions" {
  class Partnership {
    status
  }

  class EventInvitation {
    status
  }

  class Follow
  class Favorite
  class Review
  class Comment
}

package "Communication" {
  class Conversation
  class Message
  class Notification
}

package "Media et categories" {
  class Image {
    type
    referenceType
  }

  class Category
  class UserCategory
  class PlaceCategory
  class ProductCategory
  class SubCategory
}

' Services principaux
AwsService --> Image : signe les URLs
ImageProcessingService --> Image : prepare les fichiers
EmailService --> User : emails auth
SocketService --> User : authentifie
SocketService --> Message : temps reel
EventsCronService --> Event : met a jour le cycle de vie
EventsCronService --> EventInvitation : annule invitations
EventStatusService --> Event : calcule status/dateRange
ScheduleService --> Place : horaires
ReviewService --> Review : notes
FollowService --> Follow : abonnements
NotificationService --> Notification : notifications
EventInvitationService --> EventInvitation : invitations

' Relations BDD principales
User "1" --> "0..1" Place : owns
User "*" --> "*" UserCategory : interests
User "0..1" --> "1" UserCategory : category
User "0..1" --> "1" Image : profile image

Place "*" --> "1" User : owner
Place "*" --> "1" PlaceCategory
Place "1" --> "*" Event

Event "*" --> "1" Place
Event "*" --> "0..1" Image
Event "*" --> "*" User : collaborators

Product "*" --> "1" User
Product "*" --> "1" ProductCategory

Category "1" --> "*" UserCategory
Category "1" --> "*" ProductCategory
Category "1" --> "*" SubCategory

Review "*" --> "1" User : author
Review "*" --> "1" Place : refPath
Review "*" --> "1" Event : refPath

Comment "*" --> "1" User : author
Comment "*" --> "1" Review : refPath
Comment "*" --> "1" Image : refPath
Comment "*" --> "1" Comment : reply

Favorite "*" --> "1" User
Favorite "*" --> "1" Place

Follow "*" --> "1" User : follower
Follow "*" --> "1" User : following

Partnership "*" --> "1" User : initiator
Partnership "*" --> "1" User : collaborator

EventInvitation "*" --> "1" Event
EventInvitation "*" --> "1" User : initiator
EventInvitation "*" --> "1" User : collaborator

Conversation "*" --> "*" User : participants
Conversation "1" --> "0..1" Message : lastMessage
Message "*" --> "1" Conversation
Message "*" --> "1" User : sender
Message "*" --> "*" User : readBy
Message "*" --> "0..1" Partnership

Notification "*" --> "1" User : sender
Notification "*" --> "1" User : receiver
Notification "*" --> "0..1" Event : refPath
Notification "*" --> "0..1" Partnership : refPath
Notification "*" --> "0..1" Conversation : refPath
Notification "*" --> "0..1" Message : refPath
Notification "*" --> "0..1" Follow : refPath

Image "*" --> "0..1" User : uploader
Image "*" --> "0..1" Place : refPath
Image "*" --> "0..1" Event : refPath
Image "*" --> "0..1" Review : refPath
Image "*" --> "0..1" Comment : refPath

@enduml
