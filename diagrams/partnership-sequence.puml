@startuml
!pragma layout smetana

skinparam shadowing false
autonumber

actor "Utilisateur" as user
participant "Frontend" as fe
participant "Controller" as ctrl
participant "PartnershipAction" as action
participant "PartnershipRepository" as repo
participant "NotificationService" as notif

== Envoi d'une demande ==

autonumber stop
user -> fe : Envoie une demande de partenariat
activate fe
autonumber resume

fe -> ctrl : POST /partnerships
activate ctrl
ctrl -> ctrl : Auth + validation
ctrl -> action : execute(partnership, initiatorId)
activate action

action -> repo : findOne(initiator + collaborator)
activate repo
alt Demande deja existante
  repo --> action : partenariat existant
  action --> ctrl : erreur
  ctrl --> fe : Erreur
else Nouvelle demande
  repo --> action : null
  action -> repo : create(status=pending)
  repo --> action : OK
  deactivate repo
  action -> notif : createNotification(partnership_invitation)
  activate notif
  notif --> action : OK
  deactivate notif
  action --> ctrl : partenariat
  deactivate action
  ctrl --> fe : 201 Created
  deactivate ctrl
  deactivate fe
end

== Reponse du collaborateur ==

autonumber stop
user -> fe : Repond a une demande de partenariat
activate fe
autonumber resume

fe -> ctrl : PUT /partnerships/update\nou DELETE /partnerships/:id
activate ctrl

alt Accepter
  ctrl -> action : execute(status=accepted)
  activate action
  action -> repo : updateOne(accepted)
  activate repo
  repo --> action : OK
  action --> ctrl : OK
  ctrl --> fe : 200 OK
else Refuser
  ctrl -> action : execute(delete)
  activate action
  action -> repo : deleteOne(partnership)
  activate repo
  repo --> action : OK
  deactivate repo
  action --> ctrl : OK
  deactivate action
  ctrl --> fe : 200 OK
  deactivate ctrl
  deactivate fe
end

@enduml
