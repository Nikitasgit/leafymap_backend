# Server Configuration

NODE_ENV=development
# Use 5001 on macOS — port 5000 is reserved by AirPlay Receiver (Control Center)
PORT=5001

# Database
MONGODB_URI=mongodb://localhost:27017/leafymap
# PostgreSQL (Prisma — announcements CMS). Start with: docker compose up -d
DATABASE_URL=postgresql://leafymap:leafymap@localhost:5432/leafymap?schema=public

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key

# AWS S3 Configuration
AWS_REGION=your_aws_region
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_BUCKET_NAME=your_s3_bucket_name

# CORS (Optional - for production)
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Email (Brevo - 300 emails/jour gratuits, même config en dev et en prod)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=votre_email_brevo
SMTP_PASS=votre_cle_smtp_brevo
MAIL_FROM=noreply@votredomaine.com

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:3001

# Google OAuth (same Client ID as frontend, for id_token verification)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
